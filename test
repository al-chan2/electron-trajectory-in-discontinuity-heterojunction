import numpy as np
import matplotlib.pyplot as plt

# Simulate the rotating phase and its effect on amplitude
angles_deg = np.linspace(0, 360, 500)
angles_rad = np.radians(angles_deg)

# The amplitude crush function (modeling the exponential decay across the gauge)
# Starts at 1.0 (PAni), ends at 0.03 (TiO2) over the full 360 degree rotation
amplitude_decay = np.exp(np.log(0.03) * (angles_deg / 360.0))

# Calculate Real and Imaginary components
Re_Psi = amplitude_decay * np.cos(angles_rad)
Im_Psi = amplitude_decay * np.sin(angles_rad)

# Plotting the relationship
fig, ax = plt.subplots(figsize=(8, 8))
ax.plot(Re_Psi, Im_Psi, color='blue', linewidth=2, label='Trajectory')
ax.scatter([Re_Psi[0]], [Im_Psi[0]], color='red', s=100, label='Start (PAni, Amp=1.0)', zorder=5)
ax.scatter([Re_Psi[-1]], [Im_Psi[-1]], color='green', s=100, label='End (TiO2, Amp=0.03)', zorder=5)

# Add origin lines and circle
circle = plt.Circle((0, 0), 1.0, color='gray', fill=False, linestyle='--', alpha=0.5)
ax.add_artist(circle)
ax.axhline(0, color='black', linewidth=0.5)
ax.axvline(0, color='black', linewidth=0.5)

ax.set_aspect('equal')
ax.set_xlabel('Real(\Psi)')
ax.set_ylabel('Imag(\Psi)')
ax.set_title('Phase Rotation Driving Amplitude Decay')
ax.legend()
ax.grid(True)

plt.savefig('phase_rotation_decay.png', dpi=300, bbox_inches='tight')
plt.close()
print("Plot saved.")